{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Executor",
  "version": "1.0.0",
  "identifier": "com.skill-executor.app",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev:all",
      "cwd": ".."
    },
    "devUrl": "http://localhost:38593",
    "beforeBuildCommand": {
      "script": "npm run build:web && npm run build",
      "cwd": ".."
    },
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Skill Executor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {}
}