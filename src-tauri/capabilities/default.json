{
  "$schema": "https://v2.tauri.app/schemas/2.0.0/capability.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "shell:allow-open",
    "shell:allow-execute",
    "dialog:default",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    {
      "identifier": "core:window:allow-start-dragging"
    },
    {
      "identifier": "core:window:allow-inner-size"
    }
  ]
}