{
  "name": "skill_executor",
  "version": "1.0.0",
  "description": "skill_executor - AI 编程助手",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const path=require('path');function copyDir(src,dest){if(!fs.existsSync(dest))fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).forEach(f=>{const s=path.join(src,f);const d=path.join(dest,f);if(fs.lstatSync(s).isDirectory())copyDir(s,d);else fs.copyFileSync(s,d)})}copyDir('web/public','dist/public')\"",
    "dev": "tsx watch src/index.ts",
    "dev:server": "node dist/index.js",
    "start": "node dist/index.js",
    "dev:web": "cd web && npm run dev",
    "kill-ports": "node scripts/kill-ports.js",
    "dev:all": "npm run kill-ports && concurrently \"npm run dev\" \"npm run dev:web\"",
    "build:web": "cd web && npm run build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@types/iconv-lite": "^0.0.1",
    "cors": "^2.8.5",
    "edge-tts-node": "^1.5.7",
    "express": "^4.18.2",
    "iconv-lite": "^0.7.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.5.3"
  },
  "private": true
}
