{
  "name": "skill_executor",
  "version": "1.0.0",
  "description": "skill_executor - AI 编程助手",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsx watch src/index.ts",
    "dev:server": "node dist/index.js",
    "start": "node dist/index.js",
    "dev:web": "cd web && npm run dev",
    "kill-ports": "node scripts/kill-ports.js",
    "dev:all": "npm run kill-ports && concurrently \"npm run dev\" \"npm run dev:web\"",
    "build:web": "cd web && npm run build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@types/iconv-lite": "^0.0.1",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "edge-tts-node": "^1.5.7",
    "express": "^4.18.2",
    "iconv-lite": "^0.7.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.5.3"
  },
  "private": true
}
